<% users = local_assigns[:users] %>
<% if users.any? %>
  <ul class="search-results__list">
    <% users.each do |user| %>
      <li class="search-results__item"
          data-action="click->user-search#pick"
          data-email="<%= user.email_address %>">
        <%= user.email_address %>
        <span class="field__hint" style="margin-left: 8px;">
          Saldo: <%= user.loyalty_account&.points_balance || 0 %> pts
        </span>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="search-results__empty">Sin resultados.</p>
<% end %>
