<% content_for :title, "#{@promotion.name} — Admin" %>

<section class="page-head">
  <div>
    <p class="page-head__eyebrow">Promoción</p>
    <h1 class="page-head__title"><%= @promotion.name %></h1>
  </div>
  <div class="button-row">
    <%= link_to "Editar", edit_admin_promotion_path(@promotion), class: "btn btn--ghost" %>
    <%= button_to "Eliminar", admin_promotion_path(@promotion), method: :delete,
          class: "btn btn--danger",
          form: { data: { turbo_confirm: "¿Seguro?" } } %>
  </div>
</section>

<div class="card">
  <dl>
    <dt class="field__label">Estado</dt>
    <dd>
      <span class="badge <%= @promotion.active? ? 'badge--active' : 'badge--inactive' %>">
        <%= @promotion.active? ? "Activa" : "Inactiva" %>
      </span>
    </dd>

    <dt class="field__label" style="margin-top: 16px;">Puntos para canjear</dt>
    <dd><%= @promotion.points_for_redemption %></dd>

    <dt class="field__label" style="margin-top: 16px;">Productos incluidos</dt>
    <dd>
      <% if @promotion.products.any? %>
        <ul>
          <% @promotion.products.each do |p| %>
            <li><%= link_to p.name, admin_product_path(p) %></li>
          <% end %>
        </ul>
      <% else %>
        <em style="color: var(--ink-muted);">Sin productos asociados.</em>
      <% end %>
    </dd>
  </dl>
</div>
