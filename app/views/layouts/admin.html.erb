<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || "Admin — Bazar Salamone" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="application-name" content="Bazar Salamone">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..600,30..100;1,9..144,300..600,30..100&family=Geist:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "admin", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="admin">
    <header class="admin-nav">
      <div class="admin-nav__brand">
        <%= link_to "Bazar Salamone", admin_points_conversion_rules_path, class: "admin-nav__wordmark" %>
        <span class="admin-nav__eyebrow">Panel interno</span>
      </div>
      <nav class="admin-nav__links">
        <%= link_to "Productos", admin_products_path, class: "admin-nav__link" %>
        <%= link_to "Promociones", admin_promotions_path, class: "admin-nav__link" %>
        <%= link_to "Reglas", admin_points_conversion_rules_path, class: "admin-nav__link" %>
        <%= link_to "Otorgar puntos", new_admin_points_award_path, class: "admin-nav__link admin-nav__link--cta" %>
        <%= button_to "Salir", admin_session_path, method: :delete, class: "admin-nav__logout" %>
      </nav>
    </header>

    <main class="admin-main">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>
  </body>
</html>
